{
  "hooks": {
    "SessionStart": [
      { "matcher": "*", "hooks": [
        { "type": "command", "command": "pwsh -NoProfile -File ${CLAUDE_PLUGIN_ROOT}/hooks/session-start.ps1" }
      ]}
    ],
    "PreCompact": [
      { "matcher": "*", "hooks": [
        { "type": "agent", "agent": "memory-finalizer" }
      ]}
    ],
    "PostCompact": [
      { "matcher": "*", "hooks": [
        { "type": "command", "command": "pwsh -NoProfile -File ${CLAUDE_PLUGIN_ROOT}/hooks/post-compact.ps1" }
      ]}
    ],
    "Stop": [
      { "matcher": "*", "hooks": [
        { "type": "command", "command": "pwsh -NoProfile -File ${CLAUDE_PLUGIN_ROOT}/hooks/stop-finalize.ps1" }
      ]}
    ],
    "SubagentStop": [
      { "matcher": "*", "hooks": [
        { "type": "command", "command": "pwsh -NoProfile -File ${CLAUDE_PLUGIN_ROOT}/hooks/subagent-contract-audit.ps1" }
      ]}
    ],
    "PreToolUse": [
      { "matcher": "Write|Edit", "hooks": [
        { "type": "command", "command": "pwsh -NoProfile -File ${CLAUDE_PLUGIN_ROOT}/hooks/block-secrets.ps1" }
      ]}
    ]
  }
}
