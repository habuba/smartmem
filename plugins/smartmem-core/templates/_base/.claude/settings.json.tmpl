{
  "autoMemoryEnabled": {{autoMemoryEnabled}},
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Edit(memory/**)",
      "Write(memory/**)",
      "Edit(docs/**)",
      "Write(docs/**)",
      "Edit(.claude/smartmem/**)",
      "Write(.claude/smartmem/**)"
    ]
  },
  "env": {
    "SMARTMEM_VERSION": "0.3.0"
  }
}
